# Sanity — kopiera hela filen till .env.local i projektroten:
#   cp .env.example .env.local
# (justera bara om du byter dataset eller token)

# Project ID hittar du under: sanity.io/manage → Kajmagasinet → API
NEXT_PUBLIC_SANITY_PROJECT_ID=u9055wza
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2026-04-18

# Valfritt: Studio-URL (default http://localhost:3000/studio)
# NEXT_PUBLIC_SANITY_STUDIO_URL=http://localhost:3000/studio

# Server only — behövs för utkast-läge / preview (lägg även in i Vercel → Environment Variables)
# SANITY_API_READ_TOKEN=
# SANITY_VIEWER_TOKEN=
